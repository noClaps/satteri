{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": ["crates/**"],
  "workspaces": {
    "packages/satteri": {
      "entry": ["bench/**/*.{ts,mjs}", "test/**/*.ts"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["@emnapi/runtime", "@napi-rs/wasm-runtime"]
    }
  },
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  }
}
